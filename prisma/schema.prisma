generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Programa {
  id     String @id @default(cuid())
  nombre String @unique
}

model AppSetting {
  key       String   @id
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  firstName     String?
  lastName      String?
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(DOCENTE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailAliases  UserEmailAlias[]
  accounts      Account[]
  sessions      Session[]
  authenticators Authenticator[]
  docenteProfile Docente?
  asistenteProfile AsistenteZoom?
  createdSolicitudes SolicitudSala[] @relation("SolicitudCreatedBy")
  manualResolutions ResolucionManualProvision[]
  assignedAsistencias AsignacionAsistente[] @relation("AssignedByUser")
  notifications Notificacion[]
  audits Auditoria[] @relation("AuditActor")
  incidentReports Incidencia[] @relation("IncidenciaReportadaPor")
  incidentAssigned Incidencia[] @relation("IncidenciaAsignadaA")
  tarifasCreadas TarifaAsistenciaGlobal[] @relation("TarifaCreadaPor")
  tarifasAprobadas TarifaAsistenciaGlobal[] @relation("TarifaAprobadaPor")
  liquidacionesGeneradas Liquidacion[] @relation("LiquidacionGeneradaPor")
  liquidacionesRevisadas Liquidacion[] @relation("LiquidacionRevisadaPor")
  liquidacionesPagadas Liquidacion[] @relation("LiquidacionPagadaPor")
  pushSubscriptions     PushSubscription[]
  lastLoginAt          DateTime?
  lastLoginIp          String?
  lastLoginUserAgent   String?
  lastLoginProvider    String?
}

model UserEmailAlias {
  id        String   @id @default(cuid())
  userId    String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Docente {
  id                String          @id @default(cuid())
  usuarioId         String          @unique
  unidadAcademica   String?
  documentoIdentidad String?
  observaciones     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  usuario           User            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  solicitudes       SolicitudSala[]
}

model AsistenteZoom {
  id                String                   @id @default(cuid())
  usuarioId         String                   @unique
  aliasOperativo    String?
  disponibleGeneral Boolean                  @default(true)
  bio               String?
  datosPago         String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  usuario           User                     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  intereses         InteresAsistenteEvento[]
  asignaciones      AsignacionAsistente[]
  disponibilidades  DisponibilidadAsistente[]
  liquidaciones     Liquidacion[]
}

model CuentaZoom {
  id                         String          @id @default(cuid())
  nombreCuenta               String
  zoomAccountId              String          @unique
  ownerEmail                 String          @unique
  clientId                   String
  clientSecretRef            String
  activa                     Boolean         @default(true)
  prioridad                  Int             @default(100)
  limiteEventosConcurrentes Int?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  solicitudesPreferidas      SolicitudSala[] @relation("SolicitudCuentaPreferida")
  solicitudesAsignadas       SolicitudSala[] @relation("SolicitudCuentaAsignada")
  eventos                    EventoZoom[]
  manualResolutions          ResolucionManualProvision[]
}

model SolicitudSala {
  id                    String                    @id @default(cuid())
  docenteId             String
  createdByUserId       String
  cuentaZoomPreferidaId String?
  cuentaZoomAsignadaId  String?
  titulo                String
  responsableNombre     String?
  programaNombre        String?
  descripcion           String?
  finalidadAcademica    String?
  modalidadReunion      ModalidadReunion
  tipoInstancias        TipoInstancias
  meetingIdEstrategia   MeetingIdEstrategia      @default(UNICO_PREFERIDO)
  meetingPrincipalId    String?
  motivoMultiplesIds    String?
  fechaInicioSolicitada DateTime
  fechaFinSolicitada    DateTime
  timezone              String
  capacidadEstimada     Int?
  controlAsistencia     Boolean                  @default(false)
  docentesCorreos       String?
  grabacionPreferencia  GrabacionPreferencia     @default(NO)
  requiereGrabacion     Boolean                   @default(false)
  requiereAsistencia    Boolean                   @default(false)
  motivoAsistencia      String?
  regimenEncuentros     String?
  fechaFinRecurrencia   DateTime?
  patronRecurrencia     Json?
  fechasInstancias      Json?
  cantidadInstancias    Int                       @default(1)
  estadoSolicitud       EstadoSolicitudSala       @default(REGISTRADA)
  observacionesAdmin    String?
  canceladaPorDocenteAt DateTime?
  canceladaMotivo       String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  docente               Docente                   @relation(fields: [docenteId], references: [id], onDelete: Restrict)
  createdBy             User                      @relation("SolicitudCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  cuentaZoomPreferida   CuentaZoom?               @relation("SolicitudCuentaPreferida", fields: [cuentaZoomPreferidaId], references: [id], onDelete: SetNull)
  cuentaZoomAsignada    CuentaZoom?               @relation("SolicitudCuentaAsignada", fields: [cuentaZoomAsignadaId], references: [id], onDelete: SetNull)
  eventos               EventoZoom[]
  manualResolutions     ResolucionManualProvision[]

  @@index([docenteId, estadoSolicitud])
  @@index([estadoSolicitud, fechaInicioSolicitada])
  @@index([modalidadReunion, tipoInstancias])
}

model EventoZoom {
  id                   String                 @id @default(cuid())
  solicitudSalaId      String
  cuentaZoomId         String
  tipoEvento           TipoEventoZoom
  grupoRecurrenciaId   String?
  modalidadReunion     ModalidadReunion
  inicioProgramadoAt   DateTime
  finProgramadoAt      DateTime
  timezone             String
  requiereAsistencia   Boolean                @default(false)
  estadoCobertura      EstadoCoberturaSoporte @default(NO_REQUIERE)
  agendaAbiertaAt      DateTime?
  agendaCierraAt       DateTime?
  estadoEvento         EstadoEventoZoom       @default(PENDIENTE_CREACION)
  zoomMeetingId        String?
  zoomJoinUrl          String?
  zoomStartUrl         String?
  zoomPayloadUltimo    Json?
  sincronizadoConZoomAt DateTime?
  errorIntegracion     String?
  inicioRealAt         DateTime?
  finRealAt            DateTime?
  minutosReales        Int?
  estadoEjecucion      EstadoEjecucionEvento  @default(NO_INICIADO)
  costoEstimado        Decimal?               @db.Decimal(12, 2)
  costoReal            Decimal?               @db.Decimal(12, 2)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  solicitud            SolicitudSala          @relation(fields: [solicitudSalaId], references: [id], onDelete: Cascade)
  cuentaZoom           CuentaZoom             @relation(fields: [cuentaZoomId], references: [id], onDelete: Restrict)
  intereses            InteresAsistenteEvento[]
  asignaciones         AsignacionAsistente[]
  incidencias          Incidencia[]
  liquidacionDetalles  LiquidacionDetalle[]

  @@unique([zoomMeetingId], map: "EventoZoom_zoomMeetingId_unique")
  @@index([estadoEvento, inicioProgramadoAt])
  @@index([estadoCobertura, agendaCierraAt])
  @@index([solicitudSalaId, inicioProgramadoAt])
}

model InteresAsistenteEvento {
  id                 String                 @id @default(cuid())
  eventoZoomId       String
  asistenteZoomId    String
  estadoInteres      EstadoInteresAsistente
  comentario         String?
  fechaRespuestaAt   DateTime               @default(now())
  puedeRetirarHastaAt DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  evento             EventoZoom             @relation(fields: [eventoZoomId], references: [id], onDelete: Cascade)
  asistente          AsistenteZoom          @relation(fields: [asistenteZoomId], references: [id], onDelete: Cascade)

  @@unique([eventoZoomId, asistenteZoomId])
  @@index([eventoZoomId, estadoInteres])
}

model AsignacionAsistente {
  id                   String                 @id @default(cuid())
  eventoZoomId         String
  asistenteZoomId      String
  tipoAsignacion       TipoAsignacionAsistente @default(PRINCIPAL)
  estadoAsignacion     EstadoAsignacion       @default(ASIGNADO)
  asignadoPorUsuarioId String
  motivoAsignacion     String?
  reasignacionDeId     String?
  fechaAsignacionAt    DateTime               @default(now())
  fechaRespuestaAt     DateTime?
  modalidadSnapshot    ModalidadReunion
  tarifaAplicadaHora   Decimal                @db.Decimal(10, 2)
  moneda               String
  montoEstimado        Decimal?               @db.Decimal(12, 2)
  montoConfirmado      Decimal?               @db.Decimal(12, 2)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  evento               EventoZoom             @relation(fields: [eventoZoomId], references: [id], onDelete: Cascade)
  asistente            AsistenteZoom          @relation(fields: [asistenteZoomId], references: [id], onDelete: Restrict)
  asignadoPor          User                   @relation("AssignedByUser", fields: [asignadoPorUsuarioId], references: [id], onDelete: Restrict)
  reasignacionDe       AsignacionAsistente?   @relation("Reasignacion", fields: [reasignacionDeId], references: [id], onDelete: SetNull)
  reasignaciones       AsignacionAsistente[]  @relation("Reasignacion")
  liquidacionDetalles  LiquidacionDetalle[]

  @@index([eventoZoomId, estadoAsignacion])
  @@index([asistenteZoomId, estadoAsignacion])
}

model DisponibilidadAsistente {
  id                 String               @id @default(cuid())
  asistenteZoomId    String
  diaSemana          Int?
  fechaEspecifica    DateTime?
  horaDesde          String
  horaHasta          String
  timezone           String
  tipoDisponibilidad TipoDisponibilidad
  vigenteDesdeAt     DateTime?
  vigenteHastaAt     DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  asistente          AsistenteZoom        @relation(fields: [asistenteZoomId], references: [id], onDelete: Cascade)

  @@index([asistenteZoomId, diaSemana])
}

model TarifaAsistenciaGlobal {
  id                String             @id @default(cuid())
  modalidadReunion  ModalidadReunion
  valorHora         Decimal            @db.Decimal(10, 2)
  moneda            String
  vigenteDesde      DateTime
  vigenteHasta      DateTime?
  estado            EstadoTarifa       @default(ACTIVA)
  motivoCambio      String?
  creadoPorUsuarioId String
  aprobadoPorUsuarioId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  creadoPor         User               @relation("TarifaCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  aprobadoPor       User?              @relation("TarifaAprobadaPor", fields: [aprobadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([modalidadReunion, estado, vigenteDesde])
}

model Liquidacion {
  id                String             @id @default(cuid())
  asistenteZoomId   String
  periodoDesde      DateTime
  periodoHasta      DateTime
  estadoLiquidacion EstadoLiquidacion  @default(BORRADOR)
  subtotal          Decimal            @db.Decimal(12, 2)
  ajustes           Decimal            @default(0) @db.Decimal(12, 2)
  total             Decimal            @db.Decimal(12, 2)
  moneda            String
  generadoPorUsuarioId String
  revisadoPorUsuarioId String?
  pagadoPorUsuarioId String?
  fechaPagoAt       DateTime?
  referenciaPago    String?
  observaciones     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  asistente         AsistenteZoom      @relation(fields: [asistenteZoomId], references: [id], onDelete: Restrict)
  generadoPor       User               @relation("LiquidacionGeneradaPor", fields: [generadoPorUsuarioId], references: [id], onDelete: Restrict)
  revisadoPor       User?              @relation("LiquidacionRevisadaPor", fields: [revisadoPorUsuarioId], references: [id], onDelete: SetNull)
  pagadoPor         User?              @relation("LiquidacionPagadaPor", fields: [pagadoPorUsuarioId], references: [id], onDelete: SetNull)
  detalles          LiquidacionDetalle[]

  @@index([asistenteZoomId, periodoDesde, periodoHasta])
}

model LiquidacionDetalle {
  id                  String            @id @default(cuid())
  liquidacionId       String
  eventoZoomId        String
  asignacionAsistenteId String
  modalidadSnapshot   ModalidadReunion
  fechaEvento         DateTime
  minutosLiquidados   Int
  tarifaHoraAplicada  Decimal           @db.Decimal(10, 2)
  montoLinea          Decimal           @db.Decimal(12, 2)
  estadoLinea         EstadoLineaLiquidacion @default(INCLUIDA)
  motivoAjuste        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  liquidacion         Liquidacion       @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  evento              EventoZoom        @relation(fields: [eventoZoomId], references: [id], onDelete: Restrict)
  asignacion          AsignacionAsistente @relation(fields: [asignacionAsistenteId], references: [id], onDelete: Restrict)

  @@unique([liquidacionId, asignacionAsistenteId])
}

model Notificacion {
  id                 String              @id @default(cuid())
  usuarioId          String
  tipoNotificacion   TipoNotificacion
  canalDestino       String
  asunto             String
  cuerpo             String
  estadoEnvio        EstadoEnvioNotificacion @default(PENDIENTE)
  intentoCount       Int                 @default(0)
  ultimoIntentoAt    DateTime?
  entidadReferenciaTipo String?
  entidadReferenciaId String?
  leidaAt            DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  usuario            User                @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, estadoEnvio, createdAt])
}

model Auditoria {
  id                 String              @id @default(cuid())
  actorUsuarioId     String?
  accion             String
  entidadTipo        String
  entidadId          String
  valorAnterior      Json?
  valorNuevo         Json?
  ip                 String?
  userAgent          String?
  correlacionId      String?
  createdAt          DateTime            @default(now())

  actor              User?               @relation("AuditActor", fields: [actorUsuarioId], references: [id], onDelete: SetNull)

  @@index([entidadTipo, entidadId, createdAt])
}

model Incidencia {
  id                 String              @id @default(cuid())
  eventoZoomId       String
  reportadaPorUsuarioId String
  asignadaAUsuarioId String?
  tipoIncidencia     String
  severidad          SeveridadIncidencia
  descripcion        String
  estadoIncidencia   EstadoIncidencia    @default(ABIERTA)
  resolucion         String?
  resueltaAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  evento             EventoZoom          @relation(fields: [eventoZoomId], references: [id], onDelete: Cascade)
  reportadaPor       User                @relation("IncidenciaReportadaPor", fields: [reportadaPorUsuarioId], references: [id], onDelete: Restrict)
  asignadaA          User?               @relation("IncidenciaAsignadaA", fields: [asignadaAUsuarioId], references: [id], onDelete: SetNull)

  @@index([eventoZoomId, estadoIncidencia])
}

model ResolucionManualProvision {
  id                 String              @id @default(cuid())
  solicitudSalaId    String
  usuarioAdministradorId String
  cuentaZoomAsignadaId String
  motivoSistema      String
  accionTomada       String
  zoomMeetingIdManual String?
  zoomJoinUrlManual  String?
  observaciones      String?
  evidenciaPayload   Json?
  resueltoAt         DateTime            @default(now())
  createdAt          DateTime            @default(now())

  solicitud          SolicitudSala       @relation(fields: [solicitudSalaId], references: [id], onDelete: Cascade)
  usuarioAdministrador User              @relation(fields: [usuarioAdministradorId], references: [id], onDelete: Restrict)
  cuentaZoomAsignada CuentaZoom          @relation(fields: [cuentaZoomAsignadaId], references: [id], onDelete: Restrict)

  @@index([solicitudSalaId, resueltoAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

enum UserRole {
  ADMINISTRADOR
  CONTADURIA
  SOPORTE_ZOOM
  ASISTENTE_ZOOM
  DOCENTE
}

enum ModalidadReunion {
  HIBRIDA
  VIRTUAL
}

enum GrabacionPreferencia {
  SI
  NO
  A_DEFINIR
}

enum TipoInstancias {
  UNICA
  MULTIPLE_COMPATIBLE_ZOOM
  MULTIPLE_NO_COMPATIBLE_ZOOM
}

enum MeetingIdEstrategia {
  UNICO_REQUERIDO
  UNICO_PREFERIDO
  MULTIPLE_PERMITIDO
}

enum EstadoSolicitudSala {
  REGISTRADA
  PROVISIONANDO
  PROVISIONADA
  PENDIENTE_RESOLUCION_MANUAL_ID
  SIN_CAPACIDAD_ZOOM
  CANCELADA_DOCENTE
  CANCELADA_ADMIN
}

enum TipoEventoZoom {
  SINGLE
  RECURRENCE_INSTANCE
}

enum EstadoCoberturaSoporte {
  NO_REQUIERE
  REQUERIDO_SIN_ASIGNAR
  ASIGNADO
  CONFIRMADO
  CANCELADO
}

enum EstadoEventoZoom {
  PENDIENTE_CREACION
  CREADO_ZOOM
  ERROR_INTEGRACION
  PROGRAMADO
  CANCELADO
  FINALIZADO
}

enum EstadoEjecucionEvento {
  NO_INICIADO
  EN_CURSO
  EJECUTADO
  NO_REALIZADO
}

enum EstadoInteresAsistente {
  ME_INTERESA
  NO_ME_INTERESA
  RETIRADO
}

enum TipoAsignacionAsistente {
  PRINCIPAL
  APOYO
}

enum EstadoAsignacion {
  ASIGNADO
  ACEPTADO
  RECHAZADO
  REASIGNADO
  CANCELADO
}

enum TipoDisponibilidad {
  DISPONIBLE
  NO_DISPONIBLE
  PREFERENTE
}

enum EstadoTarifa {
  ACTIVA
  INACTIVA
}

enum EstadoLiquidacion {
  BORRADOR
  CERRADA
  APROBADA_CONTADURIA
  PAGADA
  ANULADA
}

enum EstadoLineaLiquidacion {
  INCLUIDA
  AJUSTADA
  EXCLUIDA
}

enum TipoNotificacion {
  EMAIL
  IN_APP
  ALERTA_OPERATIVA
}

enum EstadoEnvioNotificacion {
  PENDIENTE
  ENVIADA
  FALLIDA
}

enum SeveridadIncidencia {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum EstadoIncidencia {
  ABIERTA
  EN_ANALISIS
  RESUELTA
  CERRADA
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
