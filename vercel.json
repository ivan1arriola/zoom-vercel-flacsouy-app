{
  "version": 2,
  "functions": {
    "app/api/zoom-drive/sync/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/zoom-drive-sync/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/zoom-rooms-process/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/zoom-rooms-reminders/route.ts": {
      "maxDuration": 300
    },
    "app/api/zoom-drive/webhook/route.ts": {
      "maxDuration": 60
    },
    "app/api/zoom-rooms/process/route.ts": {
      "maxDuration": 300
    },
    "app/api/zoom-rooms/reminders/run/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/zoom-drive-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/zoom-rooms-process",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/zoom-rooms-reminders",
      "schedule": "*/15 * * * *"
    }
  ]
}
