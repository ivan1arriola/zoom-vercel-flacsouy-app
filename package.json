{
  "name": "zoom-platform-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "check:encoding": "node scripts/check-encoding.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "deploy:postcommit": "node scripts/deploy-after-commit.mjs",
    "size:app": "node scripts/app-size.mjs",
    "analyze:health": "node scripts/analyze-health.mjs",
    "analyze:health:ci": "node scripts/analyze-health.mjs --ci",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "googleapis": "^150.0.1",
    "next": "^15.5.5",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^7.0.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "prisma": "^6.16.3",
    "typescript": "^5.9.3"
  }
}
